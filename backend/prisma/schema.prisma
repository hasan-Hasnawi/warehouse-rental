generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  fullName       String
  phone          String
  role           String   // ADMIN, CLIENT, GUARD
  isActive       Boolean  @default(true)
  language       String   @default("ar")
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contracts           Contract[]        @relation("ClientContracts")
  bookings            Booking[]
  inventoryItems      Inventory[]       @relation("ClientInventory")
  payments            Payment[]         @relation("ClientPayments")
  guardReports        GuardReport[]     @relation("GuardReports")
  guardLogs           AccessLog[]       @relation("GuardAccessLogs")
  guardCollections    GuardCollection[] @relation("GuardCollections")
  guardWarehouses     Warehouse[]       @relation("GuardWarehouses")
  clientCollections   GuardCollection[] @relation("ClientCollections")
  clientServices      ExtraService[]    @relation("ClientServices")
  notifications       Notification[]
  guardTasks          GuardTask[]       @relation("GuardTasks")
  createdTasks        GuardTask[]       @relation("CreatedTasks")

  @@index([role])
}

model Group {
  id           String      @id @default(cuid())
  name         String
  investorName String
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  warehouses Warehouse[]
}

model Warehouse {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  area          Float
  address       String
  city          String
  pricePerMonth Float
  pricePer6Months Float
  status        String   @default("VACANT") // VACANT, RENTED, MAINTENANCE
  images        String   @default("[]")     // JSON array of URLs
  features      String   @default("[]")     // JSON array of amenities
  latitude      Float?
  longitude     Float?
  guardId       String?
  groupId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guard      User?      @relation("GuardWarehouses", fields: [guardId], references: [id])
  group      Group?     @relation(fields: [groupId], references: [id])
  contracts  Contract[]
  bookings   Booking[]
  accessLogs AccessLog[]
  tasks      GuardTask[]
  inventory  Inventory[]
}

model Contract {
  id             String   @id @default(cuid())
  contractNo     String   @unique
  clientId       String
  warehouseId    String
  startDate      DateTime
  endDate        DateTime
  rentAmount     Float
  depositAmount  Float
  discount       Float    @default(0)
  guardFeeMonthly Float   @default(0)
  isPreAgreed    Boolean  @default(false)
  clientPhone    String?
  clientPhone2   String?
  storedMaterials String?
  status         String   @default("PENDING") // ACTIVE, EXPIRED, TERMINATED, PENDING
  notes          String?
  signedByAdmin  Boolean  @default(false)
  signedByClient Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client    User      @relation("ClientContracts", fields: [clientId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  payments  Payment[]

  @@index([clientId])
  @@index([warehouseId])
  @@index([status])
}

model Booking {
  id          String   @id @default(cuid())
  clientId    String
  warehouseId String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  message     String?
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    User      @relation(fields: [clientId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([clientId])
  @@index([warehouseId])
}

model Payment {
  id            String    @id @default(cuid())
  contractId    String
  clientId      String
  amount        Float
  currency      String    @default("IQD")
  method        String    // ki_card, zaincash, cash, bank
  status        String    @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  referenceNo   String?   // payment gateway ref
  paidAt        DateTime?
  dueDate       DateTime
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])
  client   User     @relation("ClientPayments", fields: [clientId], references: [id])

  @@index([contractId])
  @@index([clientId])
}

model GuardCollection {
  id          String   @id @default(cuid())
  guardId     String
  clientId    String?
  contractId  String?
  amount      Float
  currency    String   @default("IQD")
  method      String   @default("cash")
  note        String?
  collectedAt DateTime @default(now())
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  guard  User  @relation("GuardCollections", fields: [guardId], references: [id])
  client User? @relation("ClientCollections", fields: [clientId], references: [id])

  @@index([guardId])
}

model GuardReport {
  id          String   @id @default(cuid())
  guardId     String
  warehouseId String?
  title       String
  description String
  severity    String   @default("info") // info, warning, emergency
  images      String   @default("[]")   // JSON array
  createdAt   DateTime @default(now())

  guard User @relation("GuardReports", fields: [guardId], references: [id])

  @@index([guardId])
}

model AccessLog {
  id          String   @id @default(cuid())
  guardId     String
  warehouseId String?
  clientId    String?
  action      String   // entry, exit, shipment_in, shipment_out
  qrCode      String?
  notes       String?
  timestamp   DateTime @default(now())
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  guard     User       @relation("GuardAccessLogs", fields: [guardId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([guardId])
}

model Inventory {
  id          String   @id @default(cuid())
  clientId    String
  warehouseId String?
  itemName    String
  subName     String?
  quantity    Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client User @relation("ClientInventory", fields: [clientId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
}

model ExtraService {
  id          String    @id @default(cuid())
  clientId    String
  warehouseId String?
  serviceType String    // cleaning, security, maintenance, other
  description String
  status      String    @default("pending") // pending, completed, cancelled
  price       Float?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  client User @relation("ClientServices", fields: [clientId], references: [id])

  @@index([clientId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // reminder, alert, info, emergency
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model GuardTask {
  id          String    @id @default(cuid())
  guardId     String
  warehouseId String?
  title       String
  description String?
  priority    String    @default("normal") // low, normal, high, urgent
  status      String    @default("pending") // pending, in_progress, completed, cancelled
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  guard     User       @relation("GuardTasks", fields: [guardId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  creator   User       @relation("CreatedTasks", fields: [createdBy], references: [id])

  @@index([guardId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?  // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
